{
  "expo": {
    "name": "Kariña - Idioma Indígena",
    "slug": "karina-idioma-indigena",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.miaoda.appc6jsx92bbkld"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "package": "com.miaoda.appc6jsx92bbkld"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-sqlite",
      "expo-font",
      "expo-system-ui",
      "expo-image",
      "expo-audio",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permitir a $(PRODUCT_NAME) acceder a la cámara para tomar una foto de perfil",
          "photosPermission": "Permitir a $(PRODUCT_NAME) acceder a la galería para seleccionar una foto de perfil"
        }
      ]
    ],
    "router": {
      "root": "src"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}